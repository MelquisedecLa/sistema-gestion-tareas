<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="380.0" prefHeight="440.0" style="-fx-background-color: #f5efe6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistemagestiontareas.controller.CrearRecordatorioController">
    <padding>
        <Insets top="16" bottom="16" left="16" right="16"/>
    </padding>

    <VBox styleClass="card" spacing="12.0">
        <padding>
            <Insets top="22" bottom="22" left="24" right="24"/>
        </padding>

        <Label text="Nuevo Recordatorio" styleClass="title-label"/>

        <Label text="TÍTULO" styleClass="field-label"/>
        <TextField fx:id="campoTitulo"/>

        <Label text="DESCRIPCIÓN" styleClass="field-label"/>
        <TextArea fx:id="campoDescripcion" prefRowCount="3"/>

        <Label text="PRIORIDAD" styleClass="field-label"/>
        <ComboBox fx:id="comboPrioridad" maxWidth="Infinity"/>

        <Label text="FECHA LÍMITE" styleClass="field-label"/>
        <DatePicker fx:id="campoFecha" maxWidth="Infinity"/>

        <Label fx:id="labelError" style="-fx-text-fill: #b3453d;" wrapText="true"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancelar" onAction="#onCancelar" styleClass="button-enlace"/>
            <Button text="Guardar Recordatorio" onAction="#onGuardar" defaultButton="true"/>
        </HBox>
    </VBox>
</VBox>