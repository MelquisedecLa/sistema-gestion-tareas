<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" prefWidth="380.0" prefHeight="420.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistemagestiontareas.controller.CrearTareaController">
    <padding>
        <Insets top="20" bottom="20" left="25" right="25"/>
    </padding>

    <Label text="Nueva Tarea" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Label text="Título"/>
    <TextField fx:id="campoTitulo"/>

    <Label text="Descripción"/>
    <TextArea fx:id="campoDescripcion" prefRowCount="3"/>

    <Label text="Prioridad"/>
    <ComboBox fx:id="comboPrioridad" maxWidth="Infinity"/>

    <Label text="Fecha límite"/>
    <DatePicker fx:id="campoFecha" maxWidth="Infinity"/>

    <Label fx:id="labelError" style="-fx-text-fill: red;" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#onCancelar" styleClass="button-enlace"/>
        <Button text="Guardar Tarea" onAction="#onGuardar" defaultButton="true"/>
    </HBox>
</VBox>